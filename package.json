{
  "name": "usdt-gateway",
  "version": "1.0.0",
  "description": "Standalone USDT Deposit/Withdrawal Gateway",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "tsx src/index.ts",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@scure/bip32": "^2.0.1",
    "bip39": "^3.1.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "node-cron": "^3.0.3",
    "tronweb": "^6.0.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.5.0",
    "typescript": "^5.8.0"
  }
